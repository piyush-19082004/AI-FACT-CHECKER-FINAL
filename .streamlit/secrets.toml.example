# =============================================================================
# Streamlit Cloud Secrets Template
# =============================================================================
# HOW TO USE:
#   LOCAL DEV  → copy to .streamlit/secrets.toml  (git-ignored — safe)
#   PRODUCTION → paste these key-value pairs into the Streamlit Cloud
#                "Secrets" panel at share.streamlit.io (never commit the file)
# =============================================================================

# ── API Keys ─────────────────────────────────────────────────────────────────

# Google Gemini — required for claim extraction + fact verification
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY = "AIza..."

# Tavily Search — optional but recommended for higher-quality evidence
# Falls back to DuckDuckGo if absent. Get a key at: https://app.tavily.com
TAVILY_API_KEY = "tvly-..."

# ── Optional Overrides ────────────────────────────────────────────────────────
# Uncomment to override the defaults baked into app/config.py

# MAX_FILE_SIZE_MB  = "10"    # Max PDF upload size (1–100)
# MAX_PDF_PAGES     = "50"    # Max pages to extract (1–500)
# MAX_CLAIMS        = "15"    # Max claims per document (1–50)
# LOG_LEVEL         = "INFO"  # DEBUG | INFO | WARNING | ERROR
