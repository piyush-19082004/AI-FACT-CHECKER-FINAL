# ── Copy this file to .env and fill in your keys ────────────────────────────
# NEVER commit .env to version control

# Preferred provider keys (use one or both)
# Groq offers a free tier (no billing). Get a key at: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini API (requires billing for current models)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Tavily Search API (optional; used as primary search engine when provided)
# Get yours at: https://app.tavily.com
TAVILY_API_KEY=

# ── Runtime / tuning (optional) ─────────────────────────────────────────────
# Max file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Max pages to process from a single PDF (default: 50)
MAX_PDF_PAGES=50

# Max claims to extract per document (default: 20)
MAX_CLAIMS=20

# Search results per claim (default: 3)
SEARCH_RESULTS_PER_CLAIM=3

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional: override LLM provider selection (groq | google). If empty, groq is
# preferred when GROQ_API_KEY is present, otherwise google is used when available.
LLM_PROVIDER=groq

# Notes:
# - Copy this file to `.env` and fill in keys before running locally.
# - Do NOT commit real keys to source control. Use CI/hosted secrets in production.
